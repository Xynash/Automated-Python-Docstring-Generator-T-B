__pycache__/
*.py[cod]
*$py.class
app/**/__pycache__/

# Environment & Secrets (CRITICAL: Do not remove)
.env
venv/
env/
ENV/

# Streamlit local settings
.streamlit/config.toml

# Project specific uploads (Temporary files)
app/uploads/*.py
!app/uploads/.gitkeep

